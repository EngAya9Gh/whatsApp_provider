generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Tenant {
  customFeatures Json? @map("custom_features")
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  passwordHash     String            @map("password_hash")
  companyName      String?           @map("company_name")
  plan             Plan              @default(FREE)
  isActive         Boolean           @default(true) @map("is_active")
  whatsappPhone    String?           @map("whatsapp_phone")
  sessionStatus    SessionStatus     @default(DISCONNECTED) @map("session_status")
  webhookUrl       String?           @map("webhook_url") @db.Text
  webhookEvents    Json?             @map("webhook_events")
  walletBalance    Float             @default(0) @map("wallet_balance")
  currency         String            @default("SAR")
  monthlyLimit     Int               @default(20) @map("monthly_limit")
  metaEnabled      Boolean           @default(false) @map("meta_enabled")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  apiKeys          ApiKey[]
  autoResponders   AutoResponder[]
  campaigns        Campaign[]
  invoices         Invoice[]
  messageLogs      MessageLog[]
  messageTemplates MessageTemplate[]
  usageRecords     UsageRecord[]
  channels         WhatsAppChannel[]
  chatThreads      ChatThread[]

  @@map("tenants")
}

model WhatsAppChannel {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  providerType      String   @default("BAILEYS") @map("provider_type") // BAILEYS or META_CLOUD
  phoneNumber       String?  @map("phone_number")
  status            String   @default("DISCONNECTED")

  // Meta Specific fields
  metaPhoneNumberId String?  @map("meta_phone_number_id")
  metaWabaId        String?  @map("meta_waba_id")
  metaAccessToken   String?  @map("meta_access_token") @db.Text
  metaAppSecret     String?  @map("meta_app_secret") @db.Text // Required for HMAC validation
  // Human-readable label for this channel (e.g. "Support Line", "+966500000000")
  name              String?  @default("") @map("name")
  displayPhoneNumber String? @map("display_phone_number") // from Meta Business Manager

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaigns         Campaign[]
  messageLogs       MessageLog[]
  chatThreads       ChatThread[]
  autoResponders    AutoResponder[]

  @@index([tenantId], map: "whatsapp_channels_tenant_id_fkey")
  @@map("whatsapp_channels")
}


model ApiKey {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  keyHash    String    @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  label      String?
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "api_keys_tenant_id_fkey")
  @@map("api_keys")
}

model MessageLog {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  channelId       String?       @map("channel_id")
  phone           String
  messageType     MessageType   @default(OTP) @map("message_type")
  status          MessageStatus @default(QUEUED)
  errorMessage    String?       @map("error_message") @db.Text
  // Meta Cloud API specific: wamid returned from Meta API on send
  metaMessageId   String?       @map("meta_message_id") @db.VarChar(200)
  // Tracks Meta delivery lifecycle: sent → delivered → read → failed
  deliveryStatus  String?       @map("delivery_status") @default("pending")
  createdAt       DateTime      @default(now()) @map("created_at")
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel         WhatsAppChannel? @relation(fields: [channelId], references: [id])

  @@index([tenantId], map: "message_logs_tenant_id_fkey")
  @@index([channelId], map: "message_logs_channel_id_fkey")
  @@index([metaMessageId], map: "message_logs_meta_message_id_idx")
  @@map("message_logs")
}

model UsageRecord {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  month          DateTime @db.Date
  messagesSent   Int      @default(0) @map("messages_sent")
  messagesFailed Int      @default(0) @map("messages_failed")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, month])
  @@map("usage_records")
}

model MessageTemplate {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  mediaMime String?  @map("media_mime")
  mediaPath String?  @map("media_path")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "message_templates_tenant_id_fkey")
  @@map("message_templates")
}

model Campaign {
  id              String              @id @default(uuid())
  tenantId        String              @map("tenant_id")
  channelId       String?             @map("channel_id")
  name            String
  message         String?             @db.Text
  status          String              @default("PENDING")
  campaignType    String              @default("BAILEYS") @map("campaign_type") // BAILEYS or META
  metaCategory    String?             @map("meta_category") // MARKETING, UTILITY, AUTHENTICATION
  createdAt       DateTime            @default(now()) @map("created_at")
  mediaMime       String?             @map("media_mime")
  mediaPath       String?             @map("media_path")
  templateId      String?             @map("template_id")
  buttons         String?             @map("buttons") @db.Text
  interactiveType String?             @map("interactive_type")
  startDate       DateTime?           @map("start_date")
  endDate         DateTime?           @map("end_date")
  totalCost       Float               @default(0) @map("total_cost")
  totalMessages   Int                 @default(0) @map("total_messages")
  interactions    ButtonInteraction[]
  targets         CampaignTarget[]
  autoResponders  AutoResponder[]
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel         WhatsAppChannel?    @relation(fields: [channelId], references: [id])

  @@index([tenantId], map: "campaigns_tenant_id_fkey")
  @@index([channelId], map: "campaigns_channel_id_fkey")
  @@map("campaigns")
}

model CampaignTarget {
  id           String              @id @default(uuid())
  campaignId   String              @map("campaign_id")
  phone        String
  status       String              @default("PENDING")
  error        String?             @db.Text
  variables    String?             @db.Text // Store JSON array of variables
  interactions ButtonInteraction[]
  campaign     Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId], map: "campaign_targets_campaign_id_fkey")
  @@map("campaign_targets")
}

model ButtonInteraction {
  id               String          @id @default(uuid())
  campaignId       String          @map("campaign_id")
  campaignTargetId String?         @map("campaign_target_id")
  tenantId         String          @map("tenant_id")
  phone            String
  buttonId         String          @map("button_id")
  buttonText       String          @map("button_text") @db.Text
  interactionType  String          @default("BUTTON") @map("interaction_type")
  createdAt        DateTime        @default(now()) @map("created_at")
  campaign         Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignTarget   CampaignTarget? @relation(fields: [campaignTargetId], references: [id])

  @@index([campaignId], map: "button_interactions_campaign_id_fkey")
  @@index([campaignTargetId], map: "button_interactions_campaign_target_id_fkey")
  @@map("button_interactions")
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber Int      @unique @default(autoincrement()) @map("invoice_number")
  tenantId      String   @map("tenant_id")
  amount        String
  description   String   @db.Text
  status        String   @default("UNPAID")
  createdAt     DateTime @default(now()) @map("created_at")
  billingCycle  String   @default("Monthly") @map("billing_cycle")
  dueDate       DateTime @default(now()) @map("due_date")
  items         Json?
  taxRate       Float?   @default(15.0) @map("tax_rate")
  taxAmount     String?  @map("tax_amount")
  buyerDetails  Json?    @map("buyer_details")
  sellerDetails Json?    @map("seller_details")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "invoices_tenant_id_fkey")
  @@map("invoices")
}

model AutoResponder {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  keyword           String    @db.Text
  matchType         String    @default("EXACT") @map("match_type")
  // responseType: TEXT | IMAGE | VIDEO | DOCUMENT | QR_CODE | META_TEMPLATE
  responseType      String    @default("TEXT") @map("response_type")
  message           String?   @db.Text
  mediaPath         String?   @map("media_path") @db.Text
  mediaUrl          String?   @map("media_url") @db.Text   // public URL for Meta media
  mediaMime         String?   @map("media_mime")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lat               Float?
  lng               Float?
  locationAddress   String?   @map("location_address")
  locationName      String?   @map("location_name")
  endDate           DateTime? @map("end_date")
  startDate         DateTime? @map("start_date")
  campaignId        String?   @map("campaign_id")
  // Meta-specific: link rule to a specific Meta channel
  channelId         String?   @map("channel_id")
  // For META_TEMPLATE response type
  metaTemplateName  String?   @map("meta_template_name")
  metaTemplateLang  String?   @map("meta_template_lang") @default("ar")
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign          Campaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  channel           WhatsAppChannel?    @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([tenantId], map: "auto_responders_tenant_id_fkey")
  @@index([campaignId], map: "auto_responders_campaign_id_fkey")
  @@index([channelId], map: "auto_responders_channel_id_fkey")
  @@map("auto_responders")
}

model PlanSetting {
  featureFlags Json? @map("feature_flags")
  id        String   @id @default(uuid())
  planCode     Plan     @unique @map("plan_code")
  name         String
  nameAr       String?  @map("name_ar")
  nameEn       String?  @map("name_en")
  price        Float
  limit        Int
  features     String   @db.Text
  featuresAr   String?  @map("features_ar") @db.Text
  featuresEn   String?  @map("features_en") @db.Text
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  isPopular    Boolean  @default(false) @map("is_popular")
  buttonTextAr String?  @map("button_text_ar")
  buttonTextEn String?  @map("button_text_en")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plan_settings")
}

enum Plan {
  FREE
  STARTER
  ADVANCED
  PRO
  ENTERPRISE
}

enum SessionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
}

enum MessageType {
  OTP
  CUSTOM
  INTERACTIVE
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model ChatThread {
  id            String       @id @default(uuid())
  tenantId      String       @map("tenant_id")
  channelId     String       @map("channel_id")
  contactPhone  String       @map("contact_phone")
  contactName   String?      @map("contact_name")
  lastMessageAt DateTime     @default(now()) @map("last_message_at")
  unreadCount   Int          @default(0) @map("unread_count")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  
  messages      ChatMessage[]
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel       WhatsAppChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channelId, contactPhone])
  @@index([tenantId], map: "chat_threads_tenant_id_fkey")
  @@map("chat_threads")
}

model ChatMessage {
  id            String     @id @default(uuid())
  threadId      String     @map("thread_id")
  direction     String     // "INBOUND" or "OUTBOUND"
  type          String     @default("TEXT") // "TEXT", "IMAGE", "VIDEO", "DOCUMENT", "AUDIO"
  content       String?    @db.Text
  hasMedia      Boolean    @default(false) @map("has_media")
  mediaUrl      String?    @map("media_url") @db.Text
  mediaMime     String?    @map("media_mime")
  status        String?    // "SENT", "DELIVERED", "READ", "FAILED" for outbound
  metaMessageId String?    @map("meta_message_id")
  createdAt     DateTime   @default(now()) @map("created_at")
  
  thread        ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId], map: "chat_messages_thread_id_fkey")
  @@map("chat_messages")
}

model SystemSetting {
  id        String   @id @default("GLOBAL")
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
